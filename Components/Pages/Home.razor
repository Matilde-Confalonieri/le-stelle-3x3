@page "/"
@inject IMatchService MatchService
@inject IStatsService StatsService

<PageTitle>Dashboard — Le Stelle 3x3</PageTitle>

@if (loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <section class="mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="section-title">TOURNAMENT CENTER</h1>
                <p class="section-subtitle mb-0">Panoramica generale — 20 Giugno 2026</p>
            </div>
        </div>

        <div class="row g-3 row-cols-2 row-cols-md-4 row-cols-lg-7">
            <div class="col"><div class="card-stat"><span class="stat-label">Partite Giocate</span><span class="stat-value">@summary.Played</span></div></div>
            <div class="col"><div class="card-stat"><span class="stat-label">Vittorie</span><span class="stat-value text-primary">@summary.Wins</span></div></div>
            <div class="col"><div class="card-stat"><span class="stat-label">Sconfitte</span><span class="stat-value">@summary.Losses</span></div></div>
            <div class="col"><div class="card-stat"><span class="stat-label">Win %</span><span class="stat-value text-tertiary">@summary.WinPercentage</span></div></div>
            <div class="col"><div class="card-stat"><span class="stat-label">Punti Fatti</span><span class="stat-value">@summary.PtsFor</span></div></div>
            <div class="col"><div class="card-stat"><span class="stat-label">Punti Subiti</span><span class="stat-value">@summary.PtsAgainst</span></div></div>
            <div class="col"><div class="card-stat bg-secondary text-on-primary"><span class="stat-label text-secondary-fixed">Differenza</span><span class="stat-value text-tertiary-fixed">@summary.Diff</span></div></div>
        </div>
    </section>

    <section class="mb-4">
        <div class="row g-4">
            <div class="col-lg-8">
                @if (nextMatch != null)
                {
                    <div class="card-match card-match-hero p-4 p-lg-5">
                        <div class="position-relative z-1">
                            <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
                                <div>
                                    <span class="badge-status-scheduled mb-3">@nextMatch.StatusDisplay.ToUpper()</span>
                                    <h3 class="text-display-lg mb-1 text-white" style="font-size:42px">PROSSIMA PARTITA</h3>
                                    <p class="text-label-caps text-secondary-fixed opacity-75 mb-0">@nextMatch.TypeDisplay.ToUpper()</p>
                                </div>
                                <div class="text-md-end">
                                    <span class="text-stat-value text-primary-fixed-dim d-block">20 GIUGNO</span>
                                    <span class="text-headline-md text-white">@nextMatch.DateTime.ToString("HH:mm")</span>
                                </div>
                            </div>
                            <div class="row align-items-center border-top border-white border-opacity-10 pt-4 mt-3">
                                <div class="col-md-4 d-flex align-items-center gap-3">
                                    <div class="avatar avatar-md border border-white border-opacity-25 bg-white bg-opacity-10">PC</div>
                                    <div>
                                        <span class="text-label-caps text-secondary-fixed d-block" style="font-size:9px">HOME</span>
                                        <span class="text-headline-sm text-white text-uppercase">LE STELLE</span>
                                    </div>
                                </div>
                                <div class="col-md-4 text-center">
                                    <span class="text-display-lg text-primary-fixed-dim fst-italic" style="font-size:36px">VS</span>
                                </div>
                                <div class="col-md-4 d-flex align-items-center gap-3 justify-content-md-end">
                                    <div class="d-md-none d-block">
                                        <span class="text-label-caps text-secondary-fixed d-block" style="font-size:9px">AWAY</span>
                                        <span class="text-headline-sm text-white text-uppercase">@nextMatch.Opponent</span>
                                    </div>
                                    <div class="avatar avatar-md bg-primary">@nextMatch.Opponent[..1]</div>
                                    <div class="d-none d-md-block">
                                        <span class="text-label-caps text-secondary-fixed d-block" style="font-size:9px">AWAY</span>
                                        <span class="text-headline-sm text-white text-uppercase">@nextMatch.Opponent</span>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-4 d-flex align-items-center gap-2 text-tertiary-fixed">
                                <span class="material-symbols-outlined" style="font-size:16px">location_on</span>
                                <span class="text-label-caps" style="font-size:11px">@nextMatch.Location</span>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card-match p-5 text-center">
                        <span class="material-symbols-outlined display-4 text-secondary">event_busy</span>
                        <p class="mt-3 text-label-caps">Nessuna partita in programma</p>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="card-match">
                    <div class="p-4 border-bottom d-flex justify-content-between align-items-center">
                        <h4 class="text-label-caps text-secondary mb-0">Risultati Recenti</h4>
                        <a href="/matches" class="text-primary text-label-caps text-decoration-none" style="font-size:10px">VEDI TUTTI</a>
                    </div>
                    @foreach (var match in recentMatches)
                    {
                        var mvp = match.PlayerStats.OrderByDescending(s => s.Evaluation).FirstOrDefault();
                        <div class="p-4 border-bottom">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <span class="text-label-caps text-secondary" style="font-size:9px">VS @match.Opponent.ToUpper()</span>
                                    <div class="d-flex align-items-center gap-2 mt-1">
                                        <span class="text-stat-sm">@match.ResultDisplay</span>
                                        @if (match.IsVictory) { <span class="badge-victory">VITTORIA</span> }
                                        else { <span class="badge-defeat">SCONFITTA</span> }
                                    </div>
                                </div>
                                @if (mvp != null) { <div class="badge-mvp"><span class="material-symbols-outlined" style="font-size:16px">workspace_premium</span></div> }
                            </div>
                            @if (mvp != null)
                            {
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar avatar-sm">@mvp.Player.FirstName[..1]@mvp.Player.LastName[..1]</div>
                                    <span class="text-label-caps text-on-surface" style="font-size:11px">MVP: @mvp.Player.FullName</span>
                                </div>
                            }
                        </div>
                    }
                    @if (!recentMatches.Any())
                    {
                        <div class="p-4 text-center text-muted">Nessuna partita giocata</div>
                    }
                </div>
            </div>
        </div>
    </section>

    <div class="row g-4">
        <div class="col-12">
            <div class="chart-card">
                <h4 class="section-title fs-5">PROSSIME PARTITE — 20 GIUGNO 2026</h4>
                <table class="table-stats mt-3">
                    <thead><tr><th>Orario</th><th>Campo</th><th>Avversario</th><th>Tipo</th><th>Stato</th></tr></thead>
                    <tbody>
                        @foreach (var m in upcomingMatches)
                        {
                            <tr>
                                <td class="text-label-caps fw-bold">@m.DateTime.ToString("HH:mm")</td>
                                <td>@m.Location</td>
                                <td class="fw-bold">@m.Opponent</td>
                                <td><span class="badge-status-scheduled">@m.TypeDisplay</span></td>
                                <td><span class="badge-status-scheduled">@m.StatusDisplay</span></td>
                            </tr>
                        }
                        @if (!upcomingMatches.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted py-3">Nessuna partita in arrivo</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private bool loading = true;
    private List<Match> recentMatches = new();
    private List<Match> upcomingMatches = new();
    private Match? nextMatch;
    private TeamSummary summary = new();

    protected override async Task OnInitializedAsync()
    {
        var allMatches = await MatchService.GetAllAsync();
        recentMatches = allMatches.Where(m => m.Status == MatchStatus.Played).Take(3).ToList();
        upcomingMatches = allMatches.Where(m => m.Status == MatchStatus.Scheduled).OrderBy(m => m.DateTime).ToList();
        nextMatch = upcomingMatches.FirstOrDefault();

        var played = allMatches.Where(m => m.Status == MatchStatus.Played).ToList();
        summary = new TeamSummary
        {
            Played = played.Count,
            Wins = played.Count(m => m.IsVictory),
            Losses = played.Count(m => !m.IsVictory),
            PtsFor = played.Sum(m => m.OurPoints),
            PtsAgainst = played.Sum(m => m.TheirPoints),
        };

        loading = false;
    }

    private class TeamSummary
    {
        public int Played { get; set; }
        public int Wins { get; set; }
        public int Losses { get; set; }
        public int PtsFor { get; set; }
        public int PtsAgainst { get; set; }
        public string WinPercentage => Played > 0 ? $"{(double)Wins / Played * 100:F0}%" : "—";
        public string Diff => (PtsFor - PtsAgainst) >= 0 ? $"+{PtsFor - PtsAgainst}" : $"{PtsFor - PtsAgainst}";
    }
}
